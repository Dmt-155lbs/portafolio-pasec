---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Portafolio de Servicio Comunitario PASEC - Daniel Martínez" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
      body {
        font-family: 'Inter', sans-serif;
      }
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Outfit', sans-serif;
      }
      .bg-grid {
        background-size: 40px 40px;
        background-image: linear-gradient(to right, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
        mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
        -webkit-mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
      }
    </style>
  </head>
  <body class="relative bg-slate-950 text-slate-50 min-h-screen">
    <div class="fixed inset-0 z-[-1] bg-grid pointer-events-none"></div>
    <div class="fixed top-0 inset-x-0 z-[-1] h-[50vh] bg-blue-500/10 blur-[120px] rounded-full pointer-events-none"></div>
    
    <nav class="fixed top-0 w-full z-50 glass-panel border-b-0 border-t-0 rounded-none bg-slate-900/60 transition-all duration-300">
      <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
        <span class="font-outfit font-bold text-xl text-gradient">PASEC</span>
        <ul class="hidden md:flex space-x-8 text-sm font-medium text-slate-300">
          <li><a href="#inicio" class="hover:text-blue-400 transition-colors">Inicio</a></li>
          <li><a href="#producto" class="hover:text-blue-400 transition-colors">Producto Mejorado</a></li>
          <li><a href="#ciudadania" class="hover:text-blue-400 transition-colors">Ciudadanía</a></li>
          <li><a href="#valores" class="hover:text-blue-400 transition-colors">Valores y Compromisos</a></li>
          <li><a href="#video" class="hover:text-blue-400 transition-colors">Video</a></li>
        </ul>
      </div>
    </nav>

    <main class="max-w-5xl mx-auto px-6 pt-24 pb-20 overflow-hidden">
      <slot />
    </main>
  </body>
</html>