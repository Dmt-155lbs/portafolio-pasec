---
import { FadeIn } from './FadeIn.tsx';
---

<section id="video" class="py-24 relative">
  <div class="absolute right-1/4 top-1/2 w-80 h-80 bg-rose-500/10 blur-[100px] rounded-full pointer-events-none"></div>

  <FadeIn client:visible>
    <div class="flex items-center gap-4 mb-16">
      <h2 class="text-3xl md:text-4xl font-bold font-outfit text-white">Carta a mi yo <span class="text-rose-400">del futuro</span></h2>
      <div class="h-px bg-slate-700 flex-1"></div>
    </div>
  </FadeIn>

  <FadeIn client:visible delay={0.2}>
    <div class="glass-panel p-8 md:p-12 rounded-2xl border-t-4 border-t-rose-500 max-w-4xl mx-auto">
      <div class="text-center mb-10">
        <h3 class="text-2xl font-bold text-slate-100 mb-4">Reflexión Final sobre FUNAPACE</h3>
        <p class="text-slate-400 max-w-2xl mx-auto leading-relaxed">
          Un recordatorio de los aprendizajes, el crecimiento personal y el impacto de la labor realizada en la Fundación Nacional de Parálisis Cerebral (FUNAPACE) con niños y adultos mayores.
        </p>
      </div>

      <div class="relative w-full overflow-hidden rounded-xl bg-slate-900 shadow-2xl aspect-video border border-slate-700/50 group">
        <!-- REEMPLAZAR EL SRC DE ESTE IFRAME CON EL LINK DEL VIDEO REAL -->
        <iframe 
          class="absolute top-0 left-0 w-full h-full"
          src="https://www.youtube.com/embed/dQw4w9WgXcQ" 
          title="Video Carta a mi yo del futuro" 
          frameborder="0" 
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
          allowfullscreen>
        </iframe>
        
        <div class="absolute inset-0 pointer-events-none rounded-xl ring-1 ring-inset ring-white/10 group-hover:ring-rose-500/50 transition-all duration-500"></div>
      </div>
    </div>
  </FadeIn>
</section>