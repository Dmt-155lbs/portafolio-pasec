---
import { FadeIn } from './FadeIn.tsx';
---

<section id="inicio" class="min-h-[80vh] flex flex-col justify-center py-20">
  <FadeIn client:visible>
    <div class="inline-block px-4 py-1.5 rounded-full glass-panel text-sm font-medium text-blue-400 mb-6">
      Semestre 8vo
    </div>
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 leading-tight">
      Portafolio de Servicio <br class="hidden md:block"/>
      <span class="text-gradient">Comunitario PASEC</span>
    </h1>
    <h2 class="text-2xl md:text-3xl text-slate-300 font-medium mb-8">
      Daniel Martínez
      <span class="block text-lg text-slate-400 mt-2 font-normal">Estudiante de Ingeniería en Ciencias de la Computación</span>
    </h2>
  </FadeIn>

  <FadeIn client:visible delay={0.2}>
    <div class="glass-panel rounded-2xl p-8 md:p-10 max-w-3xl border-l-4 border-l-blue-500 relative overflow-hidden group hover:border-l-purple-500 transition-colors duration-500">
      <div class="absolute inset-0 bg-gradient-to-r from-blue-500/10 to-purple-500/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      <p class="text-lg leading-relaxed text-slate-300 relative z-10">
        Durante mi participación en el programa PASEC, colaboré con la <strong class="text-white">Fundación Nacional de Parálisis Cerebral (FUNAPACE)</strong>. Esta experiencia me permitió trabajar directamente con niños y adultos mayores, transformando mi perspectiva profesional y ciudadana al enfrentarme a la realidad de la exclusión y la necesidad vital de infraestructuras sociales accesibles, dignas y empáticas.
      </p>
    </div>
  </FadeIn>
</section>